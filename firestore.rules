rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, name, role (admin, supervisor, operator)
    //
    // Collection: equipment
    // Fields: name, model, serialNumber, technicalInfo, photoUrl, manualUrl, createdAt
    //
    // Subcollection: equipment/{id}/parts
    // Fields: equipmentId, name, code, cost
    //
    // Subcollection: equipment/{id}/plans
    // Fields: equipmentId, description, intervalHours, partsRequired
    //
    // Collection: maintenance_records
    // Fields: equipmentId, planId, status, startDate, endDate, totalPartsCost, totalLaborCost, usedParts, notes
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "igonaugustobarbosa@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    function isSupervisor() {
      return isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'supervisor')
      );
    }

    function isOperator() {
      return isAuthenticated() && (
        isSupervisor() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'operator')
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.role in ['admin', 'supervisor', 'operator'] &&
             data.email is string;
    }

    function isValidEquipment(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 500 &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() < 2000000)) &&
             (!('manualUrl' in data) || (data.manualUrl is string && data.manualUrl.size() < 2000000));
    }

    function isValidPart(data) {
      return data.keys().hasAll(['name', 'code', 'cost']) &&
             data.name is string && data.code is string && data.cost is number;
    }

    function isValidPlan(data) {
      return data.keys().hasAll(['description', 'intervalHours']) &&
             data.description is string && data.intervalHours is number;
    }

    function isValidRecord(data) {
      return data.keys().hasAll(['equipmentId', 'status']) &&
             data.status in ['planned', 'in-progress', 'completed'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isOwner(userId) || request.auth.token.email == "igonaugustobarbosa@gmail.com");
      allow delete: if isAdmin();
    }

    match /equipment/{equipmentId} {
      allow read: if isAuthenticated();
      // Permissão total para o administrador pelo e-mail
      allow write: if isAuthenticated() && request.auth.token.email == "igonaugustobarbosa@gmail.com";
      // Permissões para outros usuários baseadas em cargo
      allow create, update: if isSupervisor() && isValidEquipment(request.resource.data);
      allow delete: if isAdmin();

      match /parts/{partId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (request.auth.token.email == "igonaugustobarbosa@gmail.com" || isSupervisor());
      }

      match /plans/{planId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (request.auth.token.email == "igonaugustobarbosa@gmail.com" || isSupervisor());
      }
    }

    match /maintenance_records/{recordId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.token.email == "igonaugustobarbosa@gmail.com";
      allow create, update: if isOperator() && isValidRecord(request.resource.data);
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
